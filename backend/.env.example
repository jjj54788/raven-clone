# ============================================
# Server
# ============================================
PORT=3001
# Comma-separated allowed origins for CORS (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# ============================================
# Database (PostgreSQL via Docker Compose)
# ============================================
DATABASE_URL="postgresql://postgres:admin123@localhost:5433/gewu_ai?schema=public"

# ============================================
# JWT Secret (any random string)
# ============================================
JWT_SECRET=gewu-super-secret-key-change-me

# ============================================
# Auth / Access Control
# ============================================
# In production, sign-ups default to invite-only unless explicitly disabled.
# AUTH_INVITE_ONLY=1
# AUTH_ALLOWLIST_EMAILS="you@example.com,friend@example.com"
# AUTH_ALLOWLIST_DOMAINS="example.com"

# ============================================
# Seed (dev)
# ============================================
# SEED_ADMIN_EMAIL=admin@gewu.local
# SEED_ADMIN_PASSWORD=change-me

# ============================================
# AI Usage Limits (small-group defaults)
# ============================================
# AI_RATE_LIMIT_PER_MINUTE=30
# AI_WEBSEARCH_RATE_LIMIT_PER_MINUTE=10
# AI_STREAM_MAX_CONCURRENCY_PER_USER=2
# AI_CREDITS_ENABLED=1
# AI_CREDIT_COST_CHAT=1
# AI_CREDIT_COST_WEBSEARCH=1
# AI_CONTEXT_MSG_LIMIT=100     # Max history messages loaded per session (default: 100)

# ============================================
# Debate (Multi-agent collaboration)
# ============================================
# DEBATE_MAX_ROUNDS=10
# DEBATE_SCORING_ENABLED=1
# DEBATE_SUMMARY_ENABLED=1
# DEBATE_HISTORY_LIMIT=8
# DEBATE_AGENT_DELAY_MS=400

# ============================================
# AI API Keys - fill in the ones you have
# ============================================
# — American Providers —
# OPENAI_API_KEY=sk-proj-xxxxxxxx   ← GPT 4.1/4o/o3-mini; also used for RAG embeddings
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx ← Claude Opus 4.6, Sonnet 4.6, Haiku 4.5
# GOOGLE_AI_API_KEY=xxxxxxxx        ← Gemini 2.5 Pro/Flash
# XAI_API_KEY=xai-xxxxxxxx          ← Grok 3 / Grok 3 Mini
# GROQ_API_KEY=gsk_xxxxxxxx         ← free tier: Llama 3.3 70B, ultra-fast inference
#
# — Chinese Providers —
# DEEPSEEK_API_KEY=sk-xxxxxxxx      ← DeepSeek V3 / R1
# QWEN_API_KEY=sk-xxxxxxxx          ← Alibaba Qwen Max/Plus/Turbo, excellent for Chinese
# ZHIPU_API_KEY=xxxxxxxx            ← 智谱 GLM-4 Plus/Flash (https://open.bigmodel.cn)
# MOONSHOT_API_KEY=sk-xxxxxxxx      ← Kimi / Moonshot 128K/32K (https://moonshot.cn)
# YI_API_KEY=xxxxxxxx               ← 零一万物 Yi Large/Medium (https://platform.lingyiwanwu.com)
# STEPFUN_API_KEY=xxxxxxxx          ← 阶跃星辰 Step-2/Step-1 (https://platform.stepfun.com)
# DOUBAO_API_KEY=xxxxxxxx           ← 豆包 Doubao Pro/Lite (Volcano Engine ARK)
# DOUBAO_PRO_ENDPOINT=              ← optional: Volcano ARK endpoint ID for Doubao Pro
# DOUBAO_LITE_ENDPOINT=             ← optional: Volcano ARK endpoint ID for Doubao Lite

# ============================================
# Web Search (Tavily - free 1000 req/month)
# Get your key at: https://tavily.com
# ============================================
# TAVILY_API_KEY=tvly-xxxxxxxx

# ============================================
# YouTube Data API
# ============================================
# YOUTUBE_API_KEY=your-youtube-api-key
# Optional: fallback RSS channels when API key is not set.
# Format: channelId|label,channelId|label
# YOUTUBE_RSS_CHANNELS=UCXZCJLdBC09xxGZ6gcdrc6A|OpenAI,UCcIXc5mJsHVYTZR1maL5l9w|DeepLearning.AI

# ============================================
# Firebase Auth (for Google Sign-In)
# ============================================
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================
# Integrations (OAuth)
# ============================================
# NOTION_CLIENT_ID=your-notion-client-id
# NOTION_CLIENT_SECRET=your-notion-client-secret
# NOTION_REDIRECT_URI=http://localhost:3001/api/v1/integrations/callback/notion
# NOTION_AUTH_URL=https://api.notion.com/v1/oauth/authorize
#
# GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
# GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/callback/google-drive
# GOOGLE_DRIVE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_DRIVE_SCOPES="https://www.googleapis.com/auth/drive.readonly"
#
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_REDIRECT_URI=http://localhost:3001/api/v1/integrations/callback/feishu
# FEISHU_AUTH_URL=https://open.feishu.cn/open-apis/authen/v1/index
#
# INTEGRATIONS_SUCCESS_REDIRECT=http://localhost:3000/profile

# ============================================
# ChatKit (Native Chat)
# ============================================
# CHATKIT_WORKFLOW_ID=your-workflow-id
# CHATKIT_WORKFLOW_VERSION=your-workflow-version

# ============================================
# OpenClaw Bridge (WeChat -> Gewu)
# ============================================
# OPENCLAW_BRIDGE_KEY=your-openclaw-bridge-key
# OPENCLAW_BRIDGE_USER_EMAIL=admin@gewu.local
# or OPENCLAW_BRIDGE_USER_ID=your-user-uuid

# ============================================
# GitHub API (for AI Store trending tracker)
# ============================================
# Optional — raises rate limit from 60 to 5000 req/hr
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
