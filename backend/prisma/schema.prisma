generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?
  provider  String   @default("local")
  avatarUrl String?
  bio       String?
  interests String[] @default([])
  settings  Json?
  integrations Json?
  credits   Int      @default(100)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  todoLists TodoList[]
  storeCustomItems StoreCustomItem[]
  dailyCheckIns DailyCheckIn[]
  teamsOwned Team[]
  teamMemberships TeamMember[]
  integrationConnections IntegrationConnection[]
  aiseRequirements AiseRequirement[]
  aiseMetrics AiseMetric[]
  aisePipelineStages AisePipelineStage[]
  aiseQualityGates AiseQualityGate[]
  aiseAcceptanceItems AiseAcceptanceItem[]
  aiseFocuses AiseFocus[]
  debateSessions DebateSession[]
  debateTemplates DebateTemplate[]
}

model Session {
  id        String   @id @default(uuid())
  title     String   @default("New Chat")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}

model Message {
  id        String   @id @default(uuid())
  role      String   // "user" | "assistant"
  content   String
  model     String?  // which AI model was used
  sessionId String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

model TodoList {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String?
  isInbox   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks TodoTask[]

  @@index([userId])
}

model TodoTask {
  id          String     @id @default(uuid())
  listId      String
  title       String
  description String?
  status      TodoStatus @default(TODO)
  priority    Int        @default(0)
  dueAt       DateTime?
  completedAt DateTime?
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  list TodoList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@index([status, dueAt])
}

model SignupAllowlistEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum StoreItemType {
  TOOL
  SKILL
}

enum StoreItemPricing {
  FREE
  FREEMIUM
  PAID
  OPEN_SOURCE
}

model StoreCustomItem {
  id                String            @id @default(uuid())
  userId            String
  type              StoreItemType
  name              String
  description       String
  url               String
  iconText          String?
  pricing           StoreItemPricing?
  categories        String[]
  tags              String[]
  trialNotesMarkdown String?
  recommendReasons  String[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model DailyCheckIn {
  id        String   @id @default(uuid())
  userId    String
  dateKey   String   // YYYY-MM-DD, computed client-side (day starts at 05:00 local)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, createdAt])
}

enum TeamMemberRole {
  OWNER
  MEMBER
}

enum TeamMissionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum TeamMissionTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  REVISION
}

enum TeamMissionActivityLevel {
  INFO
  WARNING
  ERROR
}

enum IntegrationProvider {
  NOTION
  GOOGLE_DRIVE
  FEISHU
}

model Team {
  id          String   @id @default(uuid())
  ownerUserId String
  name        String
  description String?
  tags        String[] @default([])
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members    TeamMember[]
  assistants TeamAssistant[]
  missions   TeamMission[]

  @@index([ownerUserId])
  @@index([isPublic])
}

model TeamMember {
  id        String         @id @default(uuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

model TeamAssistant {
  id              String   @id @default(uuid())
  teamId          String
  displayName     String
  modelId         String
  provider        String?
  roleTitle       String?
  roleDescription String?
  currentGoal     String?
  isLeader        Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team           Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leaderMissions TeamMission[]        @relation("TeamMissionLeader")
  tasks          TeamMissionTask[]
  activities     TeamMissionActivity[]

  @@index([teamId])
  @@index([teamId, isLeader])
}

model TeamMission {
  id                String            @id @default(uuid())
  teamId            String
  title             String
  description       String
  leaderAssistantId String?
  notificationEmail String?
  status            TeamMissionStatus @default(PENDING)
  totalTasks        Int               @default(0)
  completedTasks    Int               @default(0)
  reportMarkdown    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  team            Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leaderAssistant TeamAssistant?       @relation("TeamMissionLeader", fields: [leaderAssistantId], references: [id], onDelete: SetNull)
  tasks           TeamMissionTask[]
  activities      TeamMissionActivity[]
  sources         TeamMissionSource[]

  @@index([teamId, createdAt])
  @@index([teamId, status])
}

model TeamMissionTask {
  id             String                @id @default(uuid())
  missionId      String
  assistantId    String?
  title          String
  description    String?
  status         TeamMissionTaskStatus @default(TODO)
  sortOrder      Int                   @default(0)
  outputMarkdown String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  mission    TeamMission     @relation(fields: [missionId], references: [id], onDelete: Cascade)
  assistant  TeamAssistant?  @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  activities TeamMissionActivity[]

  @@index([missionId, sortOrder])
  @@index([assistantId])
  @@index([status])
}

model TeamMissionActivity {
  id          String                   @id @default(uuid())
  missionId   String
  taskId      String?
  assistantId String?
  level       TeamMissionActivityLevel @default(INFO)
  title       String
  message     String?
  createdAt   DateTime                 @default(now())

  mission   TeamMission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  task      TeamMissionTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assistant TeamAssistant?   @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  @@index([missionId, createdAt])
  @@index([taskId])
  @@index([assistantId])
  @@index([level])
}

model TeamMissionSource {
  id          String   @id @default(uuid())
  missionId   String
  url         String
  title       String?
  domain      String?
  snippet     String?
  trustScore  Int      @default(50)
  citedCount  Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mission TeamMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, url])
  @@index([missionId])
  @@index([trustScore])
}

model IntegrationConnection {
  id           String               @id @default(uuid())
  userId       String
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  tokenType    String?
  scope        String?
  expiresAt    DateTime?
  metadata     Json?
  connectedAt  DateTime             @default(now())
  revokedAt    DateTime?
  updatedAt    DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

enum AiseStageId {
  requirements
  design
  implementation
  testing
  acceptance
}

enum AiseStageStatus {
  done
  active
  review
  pending
}

enum AiseRequirementStatus {
  done
  active
  review
  blocked
}

enum AiseMetricId {
  lead_time
  deploy_frequency
  change_failure_rate
  mttr
}

enum AiseGateId {
  unit_tests
  code_review
  security_scan
  deployment_check
}

enum AiseGateStatus {
  pass
  pending
  running
  queued
}

enum AiseAcceptanceId {
  coverage
  defect_closure
  signoff
}

enum DebateAgentCategory {
  DEBATER
  EVALUATOR
  SPECIALIST
}

enum DebateSessionStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
}

model AiseMetric {
  id        String      @id @default(uuid())
  userId    String
  metricId  AiseMetricId
  value     String
  hint      String?
  capturedAt DateTime   @default(now())
  savedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metricId])
  @@index([userId])
}

model AisePipelineStage {
  id         String         @id @default(uuid())
  userId     String
  stageId    AiseStageId
  status     AiseStageStatus
  wipCurrent Int
  wipLimit   Int
  itemsCount Int
  desc       String?
  savedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stageId])
  @@index([userId])
}

model AiseQualityGate {
  id      String       @id @default(uuid())
  userId  String
  gateId  AiseGateId
  status  AiseGateStatus
  value   String
  savedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gateId])
  @@index([userId])
}

model AiseAcceptanceItem {
  id          String           @id @default(uuid())
  userId      String
  acceptanceId AiseAcceptanceId
  value       String
  savedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, acceptanceId])
  @@index([userId])
}

model AiseRequirement {
  id              String               @id @default(uuid())
  userId          String
  key             String
  title           String
  owner           String
  stageId         AiseStageId
  status          AiseRequirementStatus
  progress        Int
  sourceUpdatedAt DateTime
  metadata        Json?
  createdAt       DateTime             @default(now())
  savedAt         DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@index([userId, stageId])
  @@index([userId, status])
}

model AiseFocus {
  id             String               @id @default(uuid())
  userId         String
  requirementKey String
  title          String
  description    String
  stageId        AiseStageId
  status         AiseRequirementStatus
  savedAt        DateTime             @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trace AiseFocusTrace[]

  @@unique([userId, requirementKey])
  @@index([userId])
}

model AiseFocusTrace {
  id       String         @id @default(uuid())
  focusId  String
  stageId  AiseStageId
  status   AiseStageStatus
  sortOrder Int

  focus AiseFocus @relation(fields: [focusId], references: [id], onDelete: Cascade)

  @@index([focusId, sortOrder])
}

model DebateAgent {
  id           String              @id
  name         String
  profile      String
  systemPrompt String
  color        String?
  description  String?
  category     DebateAgentCategory @default(DEBATER)
  displayOrder Int                 @default(0)
  createdAt    DateTime            @default(now())

  @@index([category, displayOrder])
}

model DebateSession {
  id            String               @id @default(uuid())
  userId        String
  topic         String
  agentIds      String[]
  maxRounds     Int                  @default(5)
  currentRound  Int                  @default(0)
  status        DebateSessionStatus  @default(PENDING)
  summary       String?
  keyPoints     String[]
  consensus     String?
  disagreements String[]
  bestViewpoint String?
  mostInnovative String?
  goldenQuotes  String[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  completedAt   DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages DebateMessage[]

  @@index([userId, createdAt])
  @@index([status])
}

model DebateMessage {
  id               String   @id @default(uuid())
  sessionId        String
  senderId         String
  content          String
  round            Int
  logicScore       Float?
  innovationScore  Float?
  expressionScore  Float?
  totalScore       Float?
  scoringReasons   Json?
  createdAt        DateTime @default(now())

  session DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([senderId])
}

model DebateTemplate {
  id          String   @id
  userId      String?
  name        String
  description String?
  agentIds    String[]
  rounds      Int      @default(5)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isSystem])
}
