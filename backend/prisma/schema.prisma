generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?
  provider  String   @default("local")
  avatarUrl String?
  bio       String?
  interests String[] @default([])
  settings  Json?
  integrations Json?
  credits   Int      @default(100)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  todoLists TodoList[]
  storeCustomItems StoreCustomItem[]
  storeBookmarks StoreBookmark[]
  dailyCheckIns DailyCheckIn[]
  teamsOwned Team[]
  teamMemberships TeamMember[]
  integrationConnections IntegrationConnection[]
  aiseRequirements AiseRequirement[]
  aiseMetrics AiseMetric[]
  aisePipelineStages AisePipelineStage[]
  aiseQualityGates AiseQualityGate[]
  aiseAcceptanceItems AiseAcceptanceItem[]
  aiseFocuses AiseFocus[]
  debateAgents DebateAgent[]
  debateSessions DebateSession[]
  debateTemplates DebateTemplate[]
  knowledgeNotes KnowledgeNote[]
  insightTopics InsightTopic[]
  gameSaves GameSave[]
}

model Session {
  id        String   @id @default(uuid())
  title     String   @default("New Chat")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}

model Message {
  id        String   @id @default(uuid())
  role      String   // "user" | "assistant"
  content   String
  model     String?  // which AI model was used
  sessionId String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum RepeatRule {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model TodoList {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String?
  isInbox   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks TodoTask[]

  @@index([userId])
}

model TodoTask {
  id              String     @id @default(uuid())
  listId          String
  title           String
  description     String?
  status          TodoStatus @default(TODO)
  priority        Int        @default(0)
  dueAt           DateTime?
  completedAt     DateTime?
  position        Int        @default(0)
  color           String?
  repeatRule      RepeatRule @default(NONE)
  repeatEndAt     DateTime?
  knowledgeNoteId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  list          TodoList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  subtasks      SubTask[]
  knowledgeNote KnowledgeNote? @relation(fields: [knowledgeNoteId], references: [id], onDelete: SetNull)

  @@index([listId])
  @@index([status, dueAt])
  @@index([knowledgeNoteId])
}

model SubTask {
  id        String   @id @default(uuid())
  taskId    String
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task TodoTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, position])
}

model SignupAllowlistEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum StoreItemType {
  TOOL
  SKILL
}

enum StoreItemPricing {
  FREE
  FREEMIUM
  PAID
  OPEN_SOURCE
}

model StoreCustomItem {
  id                String            @id @default(uuid())
  userId            String
  type              StoreItemType
  name              String
  description       String
  url               String
  iconText          String?
  pricing           StoreItemPricing?
  categories        String[]
  tags              String[]
  trialNotesMarkdown String?
  recommendReasons  String[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model StoreBookmark {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model GithubRepoCache {
  repoFullName    String    @id
  stars           Int       @default(0)
  forks           Int       @default(0)
  openIssues      Int       @default(0)
  pushedAt        DateTime?
  starsSnapshot   Int       @default(0)
  starsSnapshotAt DateTime?
  starsGrowth7d   Int       @default(0)
  updatedAt       DateTime  @updatedAt
}

model GithubTrendingRepo {
  id              String    @id @default(uuid())
  repoFullName    String    @unique
  name            String
  description     String
  htmlUrl         String
  language        String?
  topics          String[]
  stars           Int       @default(0)
  forks           Int       @default(0)
  openIssues      Int       @default(0)
  pushedAt        DateTime?
  starsSnapshot   Int       @default(0)
  starsSnapshotAt DateTime?
  starsGrowth7d   Int       @default(0)
  aiSummaryZh     String?
  keyFeatures     String[]
  useCases        String[]
  limitations     String?
  evalScore       Json?
  aiAnalyzedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([stars(sort: Desc)])
  @@index([starsGrowth7d(sort: Desc)])
  @@index([pushedAt(sort: Desc)])
}

model DailyCheckIn {
  id        String   @id @default(uuid())
  userId    String
  dateKey   String   // YYYY-MM-DD, computed client-side (day starts at 05:00 local)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, createdAt])
}

model KnowledgeNote {
  id         String    @id @default(uuid())
  userId     String
  title      String
  content    String
  source     String?
  sourceUrl  String?
  tags       String[]  @default([])
  metadata   Json?
  embedding  Float[]   @default([])
  embeddedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoTasks TodoTask[]

  @@index([userId, createdAt])
}

enum TeamMemberRole {
  OWNER
  MEMBER
}

enum TeamStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum TeamAssistantStatus {
  IDLE
  RUNNING
  DONE
}

enum TeamMissionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum TeamMissionTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  REVISION
}

enum TeamMissionActivityLevel {
  INFO
  WARNING
  ERROR
}

enum IntegrationProvider {
  NOTION
  GOOGLE_DRIVE
  FEISHU
}

model Team {
  id          String   @id @default(uuid())
  ownerUserId String
  name        String
  description String?
  tags        String[] @default([])
  isPublic    Boolean    @default(false)
  goal        String?
  status      TeamStatus @default(ACTIVE)
  canvasJson  Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner      User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members    TeamMember[]
  assistants TeamAssistant[]
  missions   TeamMission[]

  @@index([ownerUserId])
  @@index([isPublic])
}

model TeamMember {
  id        String         @id @default(uuid())
  teamId    String
  userId    String
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

model TeamAssistant {
  id              String   @id @default(uuid())
  teamId          String
  displayName     String
  modelId         String
  provider        String?
  roleTitle       String?
  roleDescription String?
  currentGoal     String?
  isLeader        Boolean             @default(false)
  sortOrder       Int                 @default(0)
  catalogId       String?
  iconText        String?
  accent          String?
  asStatus        TeamAssistantStatus @default(IDLE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  team           Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leaderMissions TeamMission[]        @relation("TeamMissionLeader")
  tasks          TeamMissionTask[]
  activities     TeamMissionActivity[]

  @@index([teamId])
  @@index([teamId, isLeader])
}

model TeamMission {
  id                String            @id @default(uuid())
  teamId            String
  title             String
  description       String
  leaderAssistantId String?
  notificationEmail String?
  status            TeamMissionStatus @default(PENDING)
  totalTasks        Int               @default(0)
  completedTasks    Int               @default(0)
  reportMarkdown    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  team            Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leaderAssistant TeamAssistant?       @relation("TeamMissionLeader", fields: [leaderAssistantId], references: [id], onDelete: SetNull)
  tasks           TeamMissionTask[]
  activities      TeamMissionActivity[]
  sources         TeamMissionSource[]

  @@index([teamId, createdAt])
  @@index([teamId, status])
}

model TeamMissionTask {
  id             String                @id @default(uuid())
  missionId      String
  assistantId    String?
  title          String
  description    String?
  status         TeamMissionTaskStatus @default(TODO)
  sortOrder      Int                   @default(0)
  outputMarkdown String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  mission    TeamMission     @relation(fields: [missionId], references: [id], onDelete: Cascade)
  assistant  TeamAssistant?  @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  activities TeamMissionActivity[]

  @@index([missionId, sortOrder])
  @@index([assistantId])
  @@index([status])
}

model TeamMissionActivity {
  id          String                   @id @default(uuid())
  missionId   String
  taskId      String?
  assistantId String?
  level       TeamMissionActivityLevel @default(INFO)
  title       String
  message     String?
  createdAt   DateTime                 @default(now())

  mission   TeamMission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  task      TeamMissionTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assistant TeamAssistant?   @relation(fields: [assistantId], references: [id], onDelete: SetNull)

  @@index([missionId, createdAt])
  @@index([taskId])
  @@index([assistantId])
  @@index([level])
}

model TeamMissionSource {
  id          String   @id @default(uuid())
  missionId   String
  url         String
  title       String?
  domain      String?
  snippet     String?
  trustScore  Int      @default(50)
  citedCount  Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mission TeamMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, url])
  @@index([missionId])
  @@index([trustScore])
}

model IntegrationConnection {
  id           String               @id @default(uuid())
  userId       String
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  tokenType    String?
  scope        String?
  expiresAt    DateTime?
  metadata     Json?
  connectedAt  DateTime             @default(now())
  revokedAt    DateTime?
  updatedAt    DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

enum AiseStageId {
  requirements
  design
  implementation
  testing
  acceptance
}

enum AiseStageStatus {
  done
  active
  review
  pending
}

enum AiseRequirementStatus {
  done
  active
  review
  blocked
}

enum AiseMetricId {
  lead_time
  deploy_frequency
  change_failure_rate
  mttr
}

enum AiseGateId {
  unit_tests
  code_review
  security_scan
  deployment_check
}

enum AiseGateStatus {
  pass
  pending
  running
  queued
}

enum AiseAcceptanceId {
  coverage
  defect_closure
  signoff
}

enum DebateAgentCategory {
  DEBATER
  EVALUATOR
  SPECIALIST
}

enum DebateSessionStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
}

model AiseMetric {
  id        String      @id @default(uuid())
  userId    String
  metricId  AiseMetricId
  value     String
  hint      String?
  capturedAt DateTime   @default(now())
  savedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metricId])
  @@index([userId])
}

model AisePipelineStage {
  id         String         @id @default(uuid())
  userId     String
  stageId    AiseStageId
  status     AiseStageStatus
  wipCurrent Int
  wipLimit   Int
  itemsCount Int
  desc       String?
  savedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stageId])
  @@index([userId])
}

model AiseQualityGate {
  id      String       @id @default(uuid())
  userId  String
  gateId  AiseGateId
  status  AiseGateStatus
  value   String
  savedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gateId])
  @@index([userId])
}

model AiseAcceptanceItem {
  id          String           @id @default(uuid())
  userId      String
  acceptanceId AiseAcceptanceId
  value       String
  savedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, acceptanceId])
  @@index([userId])
}

model AiseRequirement {
  id              String               @id @default(uuid())
  userId          String
  key             String
  title           String
  owner           String
  stageId         AiseStageId
  status          AiseRequirementStatus
  progress        Int
  sourceUpdatedAt DateTime
  metadata        Json?
  createdAt       DateTime             @default(now())
  savedAt         DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@index([userId, stageId])
  @@index([userId, status])
}

model AiseFocus {
  id             String               @id @default(uuid())
  userId         String
  requirementKey String
  title          String
  description    String
  stageId        AiseStageId
  status         AiseRequirementStatus
  savedAt        DateTime             @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trace AiseFocusTrace[]

  @@unique([userId, requirementKey])
  @@index([userId])
}

model AiseFocusTrace {
  id       String         @id @default(uuid())
  focusId  String
  stageId  AiseStageId
  status   AiseStageStatus
  sortOrder Int

  focus AiseFocus @relation(fields: [focusId], references: [id], onDelete: Cascade)

  @@index([focusId, sortOrder])
}

model DebateAgent {
  id           String              @id
  userId       String?
  name         String
  profile      String
  systemPrompt String
  color        String?
  description  String?
  category     DebateAgentCategory @default(DEBATER)
  displayOrder Int                 @default(0)
  createdAt    DateTime            @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category, displayOrder])
  @@index([userId])
}

model DebateSession {
  id            String               @id @default(uuid())
  userId        String
  topic         String
  agentIds      String[]
  maxRounds     Int                  @default(5)
  currentRound  Int                  @default(0)
  status        DebateSessionStatus  @default(PENDING)
  summary       String?
  keyPoints     String[]
  consensus     String?
  disagreements String[]
  bestViewpoint String?
  mostInnovative String?
  goldenQuotes  String[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  completedAt   DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages DebateMessage[]

  @@index([userId, createdAt])
  @@index([status])
}

model DebateMessage {
  id               String   @id @default(uuid())
  sessionId        String
  senderId         String
  content          String
  round            Int
  logicScore       Float?
  innovationScore  Float?
  expressionScore  Float?
  totalScore       Float?
  scoringReasons   Json?
  createdAt        DateTime @default(now())

  session DebateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([senderId])
}

model DebateTemplate {
  id          String   @id
  userId      String?
  name        String
  description String?
  agentIds    String[]
  rounds      Int      @default(5)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isSystem])
}

// ─── AI Insights ─────────────────────────────────────────────────────────────

enum InsightVisibility {
  PUBLIC
  PRIVATE
}

enum InsightCategory {
  MACRO
  TECH
  CORP
}

enum InsightIcon {
  GLOBE
  CHIP
  BUILDING
  NETWORK
}

enum InsightTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum InsightDirectionStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum InsightAiAgentStatus {
  IDLE
  WORKING
  OFFLINE
}

enum InsightResearchStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
  PAUSED
}

model InsightTopic {
  id         String            @id @default(uuid())
  userId     String
  title      String
  subtitle   String?
  category   InsightCategory   @default(MACRO)
  visibility InsightVisibility @default(PRIVATE)
  icon       InsightIcon       @default(GLOBE)
  accent     Json?
  shareToken String?           @unique
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        InsightResearchMember[]
  aiTeam      InsightAiAgent[]
  directions  InsightDirection[]
  tasks       InsightTask[]
  research    InsightResearchSession?
  collab      InsightCollabEvent[]
  report      InsightReportSection[]
  history     InsightHistoryItem[]
  credibility InsightCredibility?
  references  InsightReference[]
  claims      InsightClaim[]

  @@index([userId, createdAt])
}

model InsightResearchMember {
  id        String @id @default(uuid())
  topicId   String
  name      String
  role      String
  status    String @default("active")
  taskCount Int    @default(0)

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model InsightAiAgent {
  id       String               @id @default(uuid())
  topicId  String
  name     String
  role     String
  model    String
  status   InsightAiAgentStatus @default(IDLE)
  isLeader Boolean              @default(false)
  focus    String?

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model InsightDirection {
  id      String                 @id @default(uuid())
  topicId String
  label   String
  status  InsightDirectionStatus @default(PENDING)

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model InsightTask {
  id       String            @id @default(uuid())
  topicId  String
  taskId   String
  title    String
  subtitle String?
  owner    String?
  model    String?
  status   InsightTaskStatus @default(PENDING)

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model InsightResearchSession {
  id          String                @id @default(uuid())
  topicId     String                @unique
  status      InsightResearchStatus @default(PENDING)
  stages      Json                  @default("[]")
  discussions Json                  @default("[]")
  output      Json?
  checkpoints Json                  @default("{}")
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model InsightCollabEvent {
  id        String   @id @default(uuid())
  topicId   String
  type      String   @default("info")
  actor     String
  detail    String
  timestamp DateTime @default(now())

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId, timestamp])
}

model InsightReportSection {
  id         String   @id @default(uuid())
  topicId    String
  sortOrder  Int      @default(0)
  title      String
  summary    String
  highlights String[] @default([])

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId, sortOrder])
}

model InsightHistoryItem {
  id                String   @id @default(uuid())
  topicId           String
  round             Int
  date              String
  dimensionsUpdated Int      @default(0)
  sourcesAdded      Int      @default(0)
  interactions      Int      @default(0)
  summary           String?
  createdAt         DateTime @default(now())

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model InsightCredibility {
  id          String   @id @default(uuid())
  topicId     String   @unique
  overall     Int      @default(0)
  metrics     Json     @default("[]")
  sources     Json     @default("[]")
  timeliness  Json     @default("[]")
  coverage    Json     @default("[]")
  quality     Json     @default("[]")
  limitations String[] @default([])
  updatedAt   DateTime @updatedAt

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model InsightReference {
  id      String  @id @default(uuid())
  topicId String
  refId   String
  title   String
  domain  String
  excerpt String?
  score   Float   @default(0)
  tag     String?

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

// Phase D2: Claim-level evidence chain
model InsightClaim {
  id             String   @id @default(uuid())
  topicId        String
  directionLabel String
  statement      String
  confidence     Float    @default(0.7)
  sourceQuery    String   @default("")
  contestedBy    String?
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())

  topic InsightTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([topicId, directionLabel])
}

// ---- Frostland Game ----
model GameSave {
  id           String   @id @default(uuid())
  userId       String
  name         String   @default("Autosave")
  gameState    Json
  daysSurvived Int      @default(0)
  score        Int      @default(0)
  isAutosave   Boolean  @default(false)
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([isCompleted, score])
}
