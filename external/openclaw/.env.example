# OpenClaw WeChat Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── WeChat Proxy API (required) ───────────────────────────────────────────
# Your WeChat Proxy API key from your proxy service provider
WECHAT_API_KEY=wc_live_xxxxxxxxxxxxxxxx

# Your WeChat Proxy service URL
WECHAT_PROXY_URL=http://your-proxy-server:3000

# ── LLM — OpenAI (required) ───────────────────────────────────────────────
# OpenAI API key — used by OpenClaw agents to generate responses in WeChat
# If this is already in your system environment, you don't need to add it here.
OPENAI_API_KEY=sk-proj-xxxxxxxx

# Model for agent responses (gpt-4o-mini is fast & cheap; gpt-4o is smarter)
OPENCLAW_LLM_MODEL=gpt-4o-mini

# Optional: custom OpenAI-compatible base URL (e.g., Azure OpenAI, local proxy)
# Leave blank to use the default api.openai.com
# OPENCLAW_LLM_BASE_URL=https://your-openai-proxy.com/v1

# ── Webhook (required for cloud deployment) ───────────────────────────────
# Your server's public IP address or domain name
# The WeChat proxy service will call this URL to deliver messages to your bot
WECHAT_WEBHOOK_HOST=1.2.3.4

# Webhook listen port (default: 18790). Make sure this port is open in firewall.
WECHAT_WEBHOOK_PORT=18790

# ── Device Type ───────────────────────────────────────────────────────────
# "ipad" (recommended) or "mac"
WECHAT_DEVICE_TYPE=ipad

# ── Gewu Bridge (optional) ───────────────────────────────────────────────
# Enables saving WeChat messages as Knowledge Notes and Todo tasks in Gewu.
# Steps:
#   1. Set OPENCLAW_BRIDGE_KEY=<random-secret> in backend/.env
#   2. Set OPENCLAW_BRIDGE_USER_EMAIL=<your-Gewu-email> in backend/.env
#   3. Set RAVEN_BRIDGE_KEY below to the same value as OPENCLAW_BRIDGE_KEY
RAVEN_BRIDGE_URL=http://localhost:3001
RAVEN_BRIDGE_KEY=your-openclaw-bridge-key
